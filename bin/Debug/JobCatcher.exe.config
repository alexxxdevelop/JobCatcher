<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
      <section name="JobCatcher.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
    </sectionGroup>
    <!-- For more information on Entity Framework configuration, visit http://go.microsoft.com/fwlink/?LinkID=237468 -->
    <section name="entityFramework" type="System.Data.Entity.Internal.ConfigFile.EntityFrameworkSection, EntityFramework, Version=6.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" requirePermission="false" />
  </configSections>
  <connectionStrings>
    <add name="connString" connectionString="Data Source=localhost;Initial Catalog=JobCatcher;Integrated Security=True;MultipleActiveResultSets=True" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <userSettings>
    <JobCatcher.Properties.Settings>
      <setting name="proxyBool" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="proxyText" serializeAs="String">
        <value>127.0.0.1:8888</value>
      </setting>
      <setting name="minimTray" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="closeTray" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="periodWork" serializeAs="String">
        <value>300</value>
      </setting>
      <setting name="letterWork" serializeAs="String">
        <value>Здравствуйте!{n}Меня заинтересовала ваша вакансия. Считаю, что мой опыт и профессиональные навыки соответствуют вашим требованиям.{n}Буду благодарен за обратную связь!</value>
      </setting>
      <setting name="letterFl" serializeAs="String">
        <value>Здравствуйте!{n}Заинтересовал ваш проект. Готов обсудить подробности</value>
      </setting>
      <setting name="periodUpdateResume" serializeAs="String">
        <value>60</value>
      </setting>
      <setting name="periodFl" serializeAs="String">
        <value>30</value>
      </setting>
      <setting name="popup" serializeAs="String">
        <value>False</value>
      </setting>
      <setting name="workEnabled" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="flEnabled" serializeAs="String">
        <value>True</value>
      </setting>
      <setting name="dateSort" serializeAs="String">
        <value>dateOld</value>
      </setting>
    </JobCatcher.Properties.Settings>
  </userSettings>
  <entityFramework>
    <defaultConnectionFactory type="System.Data.Entity.Infrastructure.SqlConnectionFactory, EntityFramework" />
    <providers>
      <provider invariantName="System.Data.SqlClient" type="System.Data.Entity.SqlServer.SqlProviderServices, EntityFramework.SqlServer" />
    </providers>
  </entityFramework>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-6.0.0.0" newVersion="6.0.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="MimeKit" publicKeyToken="bede1c8a46c66814" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.17.0.0" newVersion="4.17.0.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Buffers" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.5.0" newVersion="4.0.5.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="HtmlAgilityPack" publicKeyToken="bd319b19eaf3b43a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-1.12.4.0" newVersion="1.12.4.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>