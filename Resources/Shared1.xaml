<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="hhListGridOver" Color="#202020" />

    <Style x:Key="gridBackOver" TargetType="{x:Type Grid}">
        <Setter Property="Background" Value="{StaticResource hhListGridOver}" />
    </Style>

</ResourceDictionary>