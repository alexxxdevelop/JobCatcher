<Window x:Class="JobCatcher.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource PopupWindowStyled}" Title="" Height="180" Width="400" ShowInTaskbar="False" Topmost="True" Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource Foreground}" />
        </Style>
        <Style x:Key="varStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#34D800" />
        </Style>
        <Style x:Key="errorStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Foreground" Value="Red" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Name="profileName" Foreground="#7a7a7a"></TextBlock>
            <StackPanel Grid.Row="1" Name="panel" Orientation="Horizontal">
                <TextBlock Name="salary" FontWeight="Bold" FontSize="14"></TextBlock>
                <TextBlock Name="date" FontSize="11" VerticalAlignment="Bottom"></TextBlock>
                <TextBlock Name="city" FontSize="14" VerticalAlignment="Bottom"></TextBlock>
                <TextBlock Name="company" FontSize="14" TextDecorations="Underline" VerticalAlignment="Bottom"></TextBlock>
            </StackPanel>
            <TextBlock Grid.Row="2" Name="employmentType" TextWrapping="Wrap" MaxHeight="50"></TextBlock>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Name="detail" Height="30" FontSize="12" Click="detail_Click">Закрыть</Button>
                <Button Name="answer" Height="30" FontSize="12" Click="answer_Click">Перейти</Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
